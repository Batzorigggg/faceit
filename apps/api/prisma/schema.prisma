// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type Contact {
  facebook  String
  instagram String
  website   String
}

model BarberShop {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  location   String
  email      String   @unique
  phone      Int
  cover      String
  contacts   Contact
  password   String
  type       String
  categories String[]

  @@map("barber_shop")
}
